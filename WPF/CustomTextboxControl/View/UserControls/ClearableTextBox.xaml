<UserControl x:Class="CustomTextboxControl.View.UserControls.ClearableTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CustomTextboxControl.View.UserControls"
             mc:Ignorable="d" 
             d:DesignWidth="250" d:DesignHeight="40" FontSize="22">
    <Grid>
		<TextBox	Name="txtInput"
					Background="Transparent"
					HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
					TextChanged="TxtInput_TextChanged"
					/>
		<TextBlock	Name="tbPlaceholder" Text="Placeholder"
					FontWeight="Light" Foreground="DarkGray"
					HorizontalAlignment="Center" VerticalAlignment="Center"
					Panel.ZIndex="-1"
					/>
		<Button		Name="btnClear"
					Width="40" Height="40"
					HorizontalAlignment="Right"
					Content="X" FontSize="24"
					Background="Transparent" Foreground="DarkGray" BorderThickness="0"
					Click="BtnClear_Click"
					/>
	</Grid>
</UserControl>
